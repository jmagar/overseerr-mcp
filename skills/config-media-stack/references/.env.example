# Homelab environment template
# Copy to ~/.claude-homelab/.env and replace placeholder values.
# Keep real secrets out of git.

# Plex
# Skills
PLEX_URL=https://your-plex-url
PLEX_TOKEN=your_plex_token

# Overseerr
# Skills
OVERSEERR_URL=https://your-overseerr-url
OVERSEERR_API_KEY=your_api_key
# MCP
OVERSEERR_MCP_TOKEN=your_mcp_bearer_token
OVERSEERR_MCP_TRANSPORT=streamable-http
OVERSEERR_MCP_HOST=0.0.0.0
OVERSEERR_MCP_PORT=9151
OVERSEERR_LOG_LEVEL=DEBUG
OVERSEERR_MCP_NO_AUTH=true

# Radarr
# Skills
RADARR_URL=https://your-radarr-url
RADARR_API_KEY=your_api_key
RADARR_DEFAULT_QUALITY_PROFILE=1

# Sonarr
# Skills
SONARR_URL=https://your-sonarr-url
SONARR_API_KEY=your_api_key
SONARR_DEFAULT_QUALITY_PROFILE=1

# Prowlarr
# Skills
PROWLARR_URL=https://your-prowlarr-url
PROWLARR_API_KEY=your_api_key

# Tautulli
# Skills
TAUTULLI_URL=https://your-tautulli-url
TAUTULLI_API_KEY=your_api_key

# SABnzbd
# Skills
SABNZBD_URL=https://your-sabnzbd-url
SABNZBD_API_KEY=your_api_key

# qBittorrent
# Skills
QBITTORRENT_URL=https://your-qbittorrent-url
QBITTORRENT_USERNAME=your_username
QBITTORRENT_PASSWORD=your_password
